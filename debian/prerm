#!/bin/sh
# USBYPASS prerm
set -e

case "$1" in
    remove|upgrade|deconfigure)
        # Remove the pam-auth-update registration. pam-auth-update will
        # rebuild the common-auth stack without our hook.
        if command -v pam-auth-update >/dev/null 2>&1; then
            if [ -f /usr/share/pam-configs/usbypass ]; then
                # Deactivate our profile before its file is removed.
                pam-auth-update --package --remove usbypass || true
            fi
        fi
        ;;
    failed-upgrade)
        ;;
    *)
        echo "prerm called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
